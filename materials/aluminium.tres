[sub_resource type="Shader" id="1"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_burley, specular_schlick_ggx;
uniform vec4 albedo : source_color;
uniform sampler2D texture_albedo : source_color;
uniform float specular;
uniform float metallic;
uniform float roughness : hint_range(0, 1);
uniform float point_size : hint_range(0, 128);
uniform sampler2D texture_emission : source_color;
uniform vec4 emission : source_color;
uniform float emission_energy;
uniform sampler2D texture_normal;
uniform float normal_scale : hint_range(-16, 16);
uniform float anisotropy_ratio : hint_range(0, 256);
uniform sampler2D texture_flowmap;
uniform vec3 uv1_scale;
uniform vec3 uv1_offset;
uniform vec3 uv2_scale;
uniform vec3 uv2_offset;
uniform bool use_instance_color = false;
uniform vec4 band_color1 : source_color;
uniform vec4 band_color2 : source_color;
uniform vec4 band_color3 : source_color;
uniform vec4 band_color4 : source_color;
uniform float band_count = 4.0;

void vertex() {
	UV = UV * uv1_scale.xy + uv1_offset.xy;
}

void fragment() {
	vec2 base_uv = UV;
	vec4 albedo_tex = texture(texture_albedo, base_uv);
	ALBEDO = albedo.rgb * albedo_tex.rgb;
	// 45° diagonal bands from combined UV axes
	float d = UV.x + UV.y;
	float band_id = floor(d * band_count);
	vec4 band_colors[4] = vec4[](band_color1, band_color2, band_color3, band_color4);
	vec4 band_tint = band_colors[int(mod(band_id, band_count))];
	ALBEDO *= band_tint.rgb;
	METALLIC = metallic;
	ROUGHNESS = roughness;
	SPECULAR = specular;
	NORMAL_MAP = texture(texture_normal, base_uv).rgb;
	NORMAL_MAP_DEPTH = normal_scale;
	vec3 emission_tex = texture(texture_emission, base_uv).rgb;
	if (use_instance_color && COLOR.a > 0.01) {
		EMISSION = (COLOR.rgb + emission_tex) * COLOR.a;
	}
	vec3 anisotropy_tex = texture(texture_flowmap, base_uv).rga;
	ANISOTROPY = anisotropy_ratio * anisotropy_tex.b;
	ANISOTROPY_FLOW = anisotropy_tex.rg * 2.0 - 1.0;
}
"

[resource]
render_priority = 0
shader = SubResource("1")
shader_parameter/albedo = Color(1, 1, 1, 1)
shader_parameter/texture_albedo = ExtResource("3")
shader_parameter/specular = 0.5
shader_parameter/metallic = 1.0
shader_parameter/roughness = 0.4
shader_parameter/point_size = 1.0
shader_parameter/emission = Color(1, 0, 0, 1)
shader_parameter/emission_energy = 0.5
shader_parameter/texture_normal = ExtResource("1")
shader_parameter/normal_scale = 0.4
shader_parameter/anisotropy_ratio = 0.2
shader_parameter/texture_flowmap = ExtResource("2")
shader_parameter/uv1_scale = Vector3(1, 1, 1)
shader_parameter/uv1_offset = Vector3(0, 0, 0)
shader_parameter/uv2_scale = Vector3(1, 1, 1)
shader_parameter/uv2_offset = Vector3(0, 0, 0)
shader_parameter/use_instance_color = false
shader_parameter/band_color1 = Color(1, 1, 1, 1)
shader_parameter/band_color2 = Color(1, 1, 1, 1)
shader_parameter/band_color3 = Color(1, 1, 1, 1)
shader_parameter/band_color4 = Color(1, 1, 1, 1)
shader_parameter/band_count = 4.0
